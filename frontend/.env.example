# Copy to .env (git-ignored). Vite only exposes vars prefixed with VITE_.

# Backend REST base. Leave as /api to use the dev proxy / same-origin prod build.
VITE_API_URL=/api

# Stripe publishable key (test mode) — used for the Checkout redirect fallback.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test___PLACEHOLDER__
